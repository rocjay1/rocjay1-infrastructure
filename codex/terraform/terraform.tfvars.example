# Defaults to miniflux-494022. Override only if provisioning a separate Codex environment.
# project_id = "your-gcp-project-id"

# Optional: grant users or groups read access to the service account key secret.
# service_account_key_secret_accessor_members = [
#   "user:name@example.com",
#   "group:admins@example.com",
# ]

# Optional: grant extra project-level roles beyond the Miniflux-required set.
# additional_service_account_project_roles = [
#   "roles/logging.viewer",
# ]
